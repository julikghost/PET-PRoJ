# Copy to .env for local runs. PET: npm run pet:dev (pet-app on port 5173 by default).
LOGISTICS_BASE_CLIENT_URL=http://localhost:5173/
LOGISTICS_BASE_API_URL=http://localhost:5173/api
LOGISTICS_UI_USER_NAME=pet@example.com
LOGISTICS_PASSWORD=pet-secret
# PetAdmin — same values as VITE_PET_ADMIN_* in pet-app/.env (PetMovers CRUD tests).
LOGISTICS_ADMIN_USER_NAME=pet-admin@example.com
LOGISTICS_ADMIN_PASSWORD=pet-admin-secret
# PetAccountant — Reports-only UI; match VITE_PET_ACCOUNTANT_* in pet-app/.env (optional).
LOGISTICS_ACCOUNTANT_USER_NAME=pet-accountant@example.com
LOGISTICS_ACCOUNTANT_PASSWORD=pet-accountant-secret
E2E_LOGIN_USER_FIELD_NAME=identifier
# OIDC consent UI only — omit for local PET (avoids long waits on missing checkboxes).
# E2E_CONSENT_ROOT_SELECTOR=
# Force hosted IdP flow instead of local PET stub (localhost + identifier).
# E2E_HOSTED_LOGISTICS_LOGIN=1
E2E_TIME_ZONE=UTC

# Qase TestOps — загрузка бизнес-требований: npm run qase:push-requirements
# QASE_API_TOKEN=
# QASE_PROJECT_CODE=PET
