# Credentials accepted by the PET login form (must match root E2E env).
VITE_PET_USER=pet@example.com
VITE_PET_PASSWORD=pet-secret

# PetAdmin — full app including PetMovers and Reports.
VITE_PET_ADMIN_USER=pet-admin@example.com
VITE_PET_ADMIN_PASSWORD=pet-admin-secret

# PetAccountant — Reports only (sidebar).
VITE_PET_ACCOUNTANT_USER=pet-accountant@example.com
VITE_PET_ACCOUNTANT_PASSWORD=pet-accountant-secret

# Optional: fix port if 5173 is busy (must match LOGISTICS_BASE_CLIENT_URL in repo root .env).
# PET_DEV_PORT=5174

# Optional: Google Maps JS API key (Places + Directions) for City Taxi route preview and search-on-map.
# VITE_GOOGLE_MAPS_API_KEY=
