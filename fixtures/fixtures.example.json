{
  "_comment": "Copy to fixtures.local.json. Optional petMoverSeed; if omitted, seed is derived from reportPetMover as \"Name (CODE)\" and petMoverIdsExpected[0] for id.",
  "reportPetMover": "<exact PetMover option label as shown in Reports filter>",
  "uiPaymentMethods": ["<Payment method A>", "<Payment method B>", "<Payment method C>"],
  "uiCurrencies": ["<Currency A>", "<Currency B>"],
  "paymentCodeToName": {
    "card": "<Payment method A>",
    "cash": "<Payment method B>",
    "<api-payment-code>": "<Payment method C>"
  },
  "currencyIdToName": {
    "<currency-id-1>": "<Currency A>",
    "<currency-id-2>": "<Currency B>"
  },
  "petMoverIdsExpected": ["<pet-mover-id>"],
  "petMoverSeed": {
    "id": "<same-as-petMoverIdsExpected-0>",
    "name": "<Name>",
    "code": "<CODE>",
    "active": true,
    "currency": "EUR"
  },
  "graphql": {
    "operationName": "<ReportMutationName>",
    "queryContains": "<substring of GraphQL field or operation body>",
    "variables": {
      "req": {
        "paymentTypeNames": ["<Payment method A>", "<Payment method B>", "<Payment method C>"],
        "targetColumnForDateSearch": "departureDate",
        "fromDateDay": "CURRENT_MONTH_START",
        "toDateDay": "CURRENT_MONTH_END",
        "currencyNames": ["<Currency A>", "<Currency B>"]
      }
    }
  }
}
