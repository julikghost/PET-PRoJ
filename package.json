{
  "name": "logistics-web-e2e",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev --prefix pet-app",
    "typecheck": "tsc --noEmit",
    "lint": "npx eslint --fix",
    "e2e": "npx playwright test --config=./playwright.config.ts",
    "e2e-logistics": "npx playwright test tests --config=./playwright.config.ts",
    "postman:run": "npx newman run pet-logistics.postman_collection.json -e pet-logistics.local.postman_environment.json",
    "e2e:codegen": "node scripts/playwright-codegen.mjs",
    "e2e:codegen:booking": "node scripts/playwright-codegen.mjs /booking",
    "pet:dev": "npm run dev --prefix pet-app",
    "pet:install": "npm ci --prefix pet-app",
    "docker:pet:build": "docker build -t logistics-pet-ui ./pet-app",
    "docker:pet:up": "docker compose up --build pet-app",
    "docker:e2e:stack": "bash .github/scripts/ci/compose-e2e-stack.sh up --build --abort-on-container-exit --exit-code-from e2e",
    "qase:push-requirements": "node scripts/push-qase-requirements.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.9.0",
    "allure-playwright": "^3.0.6",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5"
  }
}
